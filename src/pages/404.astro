---
import Base from '../layouts/Base.astro';
---

<Base title="Page introuvable | allomalus." description="La page que vous cherchez n'existe pas.">
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-border">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="font-display text-xl font-black tracking-tight text-ink">allo<span class="text-brand">malus</span></a>
    </div>
  </nav>

  <div class="max-w-xl mx-auto px-6 py-32 text-center">
    <p class="text-6xl mb-6">🚗</p>
    <h1 class="font-display text-4xl font-black text-ink mb-4">Page introuvable</h1>
    <p class="text-muted text-lg mb-10">Cette page n'existe pas ou a été déplacée.</p>
    <div class="flex justify-center gap-4">
      <a href="/" class="bg-ink text-white rounded-lg px-6 py-3 font-bold text-sm hover:bg-ink/80 transition-colors">Retour a l'accueil</a>
      <a href="/devis/" class="border border-border rounded-lg px-6 py-3 font-bold text-sm text-ink hover:border-brand transition-colors">Demander un devis</a>
    </div>
  </div>
</Base>
