---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.data.slug !== post.data.slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "author": { "@type": "Person", "name": SITE.director },
  "publisher": {
    "@type": "Organization",
    "name": "Allomalus",
    "logo": { "@type": "ImageObject", "url": `${SITE.url}/favicon.svg` }
  },
  "mainEntityOfPage": `${SITE.url}/blog/${post.data.slug}/`,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE.url}/blog/` },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `${SITE.url}/blog/${post.data.slug}/` },
  ]
};
---

<Base
  title={`${post.data.title} | ${SITE.name}`}
  description={post.data.description}
  canonical={`${SITE.url}/blog/${post.data.slug}`}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-border">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="font-display text-xl font-black tracking-tight text-ink">allo<span class="text-brand">malus</span></a>
      <div class="flex items-center gap-6">
        <a href="/blog/" class="text-sm text-muted hover:text-ink transition-colors">&larr; Blog</a>
        <a href="/devis/" class="hidden sm:inline-flex bg-ink text-white rounded-lg px-5 py-2 font-bold text-sm hover:bg-ink/80 transition-colors">
          Devis gratuit
        </a>
      </div>
    </div>
  </nav>

  <!-- Breadcrumb -->
  <div class="bg-white border-b border-border">
    <div class="max-w-5xl mx-auto px-6 py-3">
      <nav class="text-xs text-muted flex items-center gap-1.5 flex-wrap">
        <a href="/" class="hover:text-ink transition-colors">Accueil</a>
        <span class="text-border">/</span>
        <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
        <span class="text-border">/</span>
        <span class="text-ink font-medium truncate max-w-[200px] sm:max-w-none">{post.data.title}</span>
      </nav>
    </div>
  </div>

  <!-- Content + Sidebar -->
  <div class="max-w-5xl mx-auto px-6 py-12 md:py-16 grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-12">

    <!-- Article -->
    <article class="min-w-0">
      <header class="mb-10">
        <span class="inline-block px-2.5 py-0.5 rounded-full bg-brand-pale text-brand text-xs font-bold mb-4">
          {post.data.category}
        </span>
        <h1 class="font-display text-[clamp(28px,4.5vw,44px)] font-black leading-[1.05] tracking-[-1.5px] text-ink mb-4">
          {post.data.title}
        </h1>
        <p class="text-muted text-lg leading-relaxed">{post.data.description}</p>
        <div class="mt-4 text-sm text-muted">
          <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatDate(post.data.date)}</time>
        </div>
      </header>

      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.title}
          class="w-full rounded-xl mb-10 border border-border"
          loading="eager"
        />
      )}

      <div class="prose prose-lg max-w-none
        prose-headings:font-display prose-headings:font-bold prose-headings:text-ink
        prose-a:text-brand prose-a:font-medium prose-a:no-underline hover:prose-a:underline
        prose-strong:text-ink
        prose-blockquote:border-brand prose-blockquote:bg-brand-pale prose-blockquote:rounded-r-lg prose-blockquote:py-1
        prose-img:rounded-xl prose-img:border prose-img:border-border
        prose-th:bg-surface prose-th:p-3 prose-th:text-left prose-th:font-display prose-th:font-bold prose-th:text-ink
        prose-td:p-3 prose-td:border-t prose-td:border-border
      ">
        <Content />
      </div>
    </article>

    <!-- Sidebar -->
    <aside class="space-y-6 lg:sticky lg:top-20 lg:self-start">
      <!-- CTA Devis -->
      <div class="rounded-xl border border-border bg-surface p-6 text-center">
        <p class="font-display font-bold text-ink text-base mb-2">Besoin d'un devis ?</p>
        <p class="text-sm text-muted mb-4">Gratuit, sans engagement.</p>
        <a href="/devis/" class="block w-full py-3 bg-ink text-white text-center font-bold text-sm rounded-lg hover:bg-ink/80 transition-colors">
          Devis gratuit &rarr;
        </a>
      </div>

      <!-- Related posts -->
      {related.length > 0 && (
        <div class="rounded-xl border border-border bg-white p-5">
          <p class="text-xs font-bold text-muted uppercase tracking-[1px] mb-3">Guides liés</p>
          <ul class="space-y-2">
            {related.map((r) => (
              <li>
                <a href={`/blog/${r.data.slug}/`} class="block text-sm text-muted hover:text-brand transition-colors leading-snug">
                  {r.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </div>

  <!-- Mobile sticky CTA -->
  <div class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-white/95 backdrop-blur-lg border-t border-border p-3">
    <a href="/devis/" class="w-full block py-3.5 bg-ink text-white text-center font-bold text-sm rounded-lg">
      Devis gratuit &rarr;
    </a>
  </div>

  <!-- Footer -->
  <footer class="border-t border-border bg-white py-8">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted">
      <div class="font-display font-black text-ink text-sm">allo<span class="text-brand">malus</span></div>
      <div class="flex items-center gap-4">
        <a href="/" class="hover:text-ink transition-colors">Accueil</a>
        <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
        <a href="/devis/" class="hover:text-ink transition-colors">Devis</a>
        <a href="/mentions-legales/" class="hover:text-ink transition-colors">Mentions légales</a>
      </div>
      <span>ORIAS {SITE.orias}</span>
    </div>
  </footer>
</Base>
