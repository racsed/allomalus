---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.data.slug !== post.data.slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": SITE.director,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Allomalus",
    "url": SITE.url,
  },
  "mainEntityOfPage": `${SITE.url}/blog/${post.data.slug}/`,
  ...(post.data.image ? { image: post.data.image } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE.url}/blog/` },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `${SITE.url}/blog/${post.data.slug}/` },
  ],
};
---

<Base
  title={`${post.data.title} | ${SITE.name}`}
  description={post.data.description}
  canonical={`${SITE.url}/blog/${post.data.slug}`}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-border">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-4 h-16">
      <a href="/" class="font-display font-black text-xl text-ink tracking-tight">
        {SITE.name}
      </a>
      <div class="flex items-center gap-6">
        <a href="/blog/" class="text-sm font-body font-medium text-muted hover:text-ink transition-colors">Blog</a>
        <a
          href="/devis/"
          class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-orange-500 text-white text-sm font-display font-bold hover:bg-orange-600 transition-colors"
        >
          Devis gratuit
        </a>
      </div>
    </div>
  </nav>

  <!-- Breadcrumb -->
  <div class="bg-surface border-b border-border">
    <div class="max-w-6xl mx-auto px-4 py-3">
      <nav aria-label="Fil d'Ariane" class="text-xs font-body text-muted flex items-center gap-1.5 flex-wrap">
        <a href="/" class="hover:text-ink transition-colors">Accueil</a>
        <span class="text-border">/</span>
        <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
        <span class="text-border">/</span>
        <span class="text-ink font-medium truncate max-w-[200px] sm:max-w-none">{post.data.title}</span>
      </nav>
    </div>
  </div>

  <!-- Content + Sidebar -->
  <div class="max-w-6xl mx-auto px-4 py-10 md:py-14 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 lg:gap-14">

    <!-- Article -->
    <article class="min-w-0">
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block px-2.5 py-0.5 rounded-full bg-orange-100 text-orange-700 text-xs font-display font-bold">
            {post.data.category}
          </span>
          {post.data.readingTime && (
            <span class="text-xs text-muted font-body">{post.data.readingTime} min de lecture</span>
          )}
        </div>
        <h1 class="font-display font-black text-3xl md:text-4xl text-ink leading-tight">
          {post.data.title}
        </h1>
        <p class="mt-3 text-muted font-body text-base md:text-lg">
          {post.data.description}
        </p>
        <div class="mt-4 flex items-center gap-3 text-sm text-muted font-body">
          <span>{SITE.director}</span>
          <span>&middot;</span>
          <time datetime={post.data.date.toISOString().slice(0, 10)}>
            {formatDate(post.data.date)}
          </time>
        </div>
      </header>

      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.imageAlt || post.data.title}
          class="w-full rounded-2xl mb-8 border border-border"
          loading="eager"
        />
      )}

      <div class="prose prose-lg max-w-none
        prose-headings:font-display prose-headings:font-bold prose-headings:text-ink
        prose-p:font-body prose-p:text-ink/80 prose-p:leading-relaxed
        prose-a:text-orange-500 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
        prose-strong:text-ink prose-strong:font-bold
        prose-ul:font-body prose-ol:font-body
        prose-li:text-ink/80
        prose-blockquote:border-orange-500 prose-blockquote:bg-orange-50 prose-blockquote:rounded-r-lg prose-blockquote:py-1
        prose-img:rounded-xl prose-img:border prose-img:border-border
        prose-code:text-orange-600 prose-code:bg-orange-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
      ">
        <Content />
      </div>
    </article>

    <!-- Sidebar -->
    <aside class="space-y-8 lg:sticky lg:top-24 lg:self-start">

      <!-- CTA Devis -->
      <div class="rounded-2xl border border-border bg-surface p-6">
        <p class="font-display font-bold text-ink text-lg">Besoin d'un devis ?</p>
        <p class="mt-2 text-sm text-muted font-body">
          Obtenez votre devis assurance auto en 2 minutes. Gratuit, sans engagement.
        </p>
        <a
          href="/devis/"
          class="mt-4 w-full inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-orange-500 text-white font-display font-bold text-sm hover:bg-orange-600 transition-colors"
        >
          Devis gratuit
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Related posts -->
      {related.length > 0 && (
        <div class="rounded-2xl border border-border bg-white p-6">
          <p class="font-display font-bold text-ink text-base mb-4">Guides liés</p>
          <ul class="space-y-3">
            {related.map((r) => (
              <li>
                <a
                  href={`/blog/${r.slug}/`}
                  class="block text-sm font-body text-muted hover:text-orange-500 transition-colors leading-snug"
                >
                  {r.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Contact -->
      <div class="rounded-2xl border border-border bg-white p-6">
        <p class="font-display font-bold text-ink text-base mb-2">Une question ?</p>
        <p class="text-sm text-muted font-body mb-3">
          Appelez-nous ou envoyez un email, on répond sous 24h.
        </p>
        <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="block text-sm font-body font-medium text-orange-500 hover:text-orange-600">
          {SITE.phone}
        </a>
        <a href={`mailto:${SITE.email}`} class="block text-sm font-body text-muted hover:text-ink mt-1">
          {SITE.email}
        </a>
      </div>
    </aside>
  </div>

  <!-- Mobile sticky CTA -->
  <div class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-white/95 backdrop-blur border-t border-border p-3">
    <a
      href="/devis/"
      class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-orange-500 text-white font-display font-bold text-sm hover:bg-orange-600 transition-colors"
    >
      Devis gratuit en 2 min
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>

  <!-- Footer -->
  <footer class="border-t border-border bg-white py-8 lg:pb-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <a href="/" class="font-display font-black text-lg text-ink">{SITE.name}</a>
          <p class="text-xs text-muted font-body mt-1">Courtier en assurance auto - ORIAS {SITE.orias}</p>
        </div>
        <nav class="flex flex-wrap items-center gap-4 text-xs text-muted font-body">
          <a href="/" class="hover:text-ink transition-colors">Accueil</a>
          <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
          <a href="/devis/" class="hover:text-ink transition-colors">Devis</a>
          <a href="/mentions-legales/" class="hover:text-ink transition-colors">Mentions légales</a>
        </nav>
      </div>
      <div class="mt-6 pt-6 border-t border-border text-xs text-muted font-body">
        &copy; {new Date().getFullYear()} Allomalus - SIREN {SITE.siren} - Tous droits réservés.
      </div>
    </div>
  </footer>

</Base>
