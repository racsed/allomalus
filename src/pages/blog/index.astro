---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/config';
import { getCollection } from 'astro:content';

const today = new Date();
const allPosts = await getCollection('blog', ({ data }) => {
  return data.date <= today;
});
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title={`Blog assurance auto malussé | Conseils et guides | ${SITE.name}`}
  description="Guides, conseils et actualités pour conducteurs malussés et résiliés. Tout comprendre sur l'assurance auto malus."
  canonical={`${SITE.url}/blog`}
>

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-border">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="font-display text-xl font-black tracking-tight text-ink"><span class="text-brand">allomalus</span><span class="text-ink">.</span></a>
      <div class="flex items-center gap-6">
        <a href="/blog/" class="text-sm font-bold text-ink">Blog</a>
        <a href="/devis/" class="hidden sm:inline-flex bg-ink text-white rounded-lg px-5 py-2 font-bold text-sm hover:bg-ink/80 transition-colors">
          Devis gratuit
        </a>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section class="bg-white py-16 md:py-20 border-b border-border">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Blog</p>
      <h1 class="font-display text-[clamp(32px,5vw,52px)] font-black tracking-[-2px] leading-[0.9] text-ink">
        Guides et conseils <span class="text-brand">auto malus</span>
      </h1>
      <p class="mt-4 text-muted text-lg max-w-xl mx-auto">
        Tout ce qu'il faut savoir pour s'assurer quand on est malussé, résilié ou en situation difficile.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="bg-surface py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-muted text-lg">Aucun article pour le moment.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map((post) => (
            <a
              href={`/blog/${post.data.slug}/`}
              class="group flex flex-col bg-white border border-border rounded-xl overflow-hidden hover:border-brand/30 hover:-translate-y-1 hover:shadow-soft transition-all duration-300"
            >
              {post.data.image ? (
                <div class="aspect-[16/9] overflow-hidden bg-surface">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="aspect-[16/9] bg-surface flex items-center justify-center">
                  <span class="text-4xl">🚗</span>
                </div>
              )}
              <div class="flex flex-col flex-1 p-5">
                <span class="inline-block w-fit px-2.5 py-0.5 rounded-full bg-brand-pale text-brand text-xs font-bold mb-3">
                  {post.data.category}
                </span>
                <h2 class="font-display font-bold text-ink leading-snug group-hover:text-brand transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-muted text-sm line-clamp-2 flex-1">
                  {post.data.description}
                </p>
                <time datetime={post.data.date.toISOString().slice(0, 10)} class="mt-4 text-xs text-muted">
                  {formatDate(post.data.date)}
                </time>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-ink py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-black text-white">
        Besoin d'un <span class="text-brand">devis</span> ?
      </h2>
      <p class="mt-3 text-white/50">
        Malussé, résilié, permis suspendu : obtenez votre devis gratuit en ligne.
      </p>
      <a href="/devis/" class="inline-flex items-center gap-2 mt-6 px-8 py-3.5 rounded-lg bg-brand text-ink font-bold hover:bg-brand-light transition-colors">
        Demander un devis &rarr;
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-white border-t border-border py-8">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted">
      <div class="font-display font-black text-ink text-sm"><span class="text-brand">allomalus</span><span class="text-ink">.</span></div>
      <div class="flex items-center gap-4">
        <a href="/mentions-legales/" class="hover:text-ink transition-colors">Mentions légales</a>
        <a href="/" class="hover:text-ink transition-colors">Accueil</a>
        <a href="/devis/" class="hover:text-ink transition-colors">Devis</a>
      </div>
      <span>ORIAS {SITE.orias} · SIREN {SITE.siren}</span>
    </div>
  </footer>
</Base>
