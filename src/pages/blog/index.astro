---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/config';
import { getCollection } from 'astro:content';

const today = new Date();
const allPosts = await getCollection('blog', ({ data }) => {
  return data.date <= today;
});
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title={`Blog assurance auto malussé | Conseils et guides | ${SITE.name}`}
  description="Guides, conseils et actualités pour conducteurs malussés et résiliés. Tout comprendre sur l'assurance auto malus."
  canonical={`${SITE.url}/blog`}
>

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-border">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-4 h-16">
      <a href="/" class="font-display font-black text-xl text-ink tracking-tight">
        {SITE.name}
      </a>
      <div class="flex items-center gap-6">
        <a href="/blog/" class="text-sm font-body font-medium text-ink">Blog</a>
        <a
          href="/devis/"
          class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-orange-500 text-white text-sm font-display font-bold hover:bg-orange-600 transition-colors"
        >
          Devis gratuit
        </a>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section class="bg-surface py-12 md:py-16 border-b border-border">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-orange-500 font-display font-bold text-sm uppercase tracking-wider mb-3">Blog</p>
      <h1 class="font-display font-black text-3xl md:text-5xl text-ink leading-tight">
        Guides et conseils <span class="font-serif italic text-orange-500">malus</span>
      </h1>
      <p class="mt-4 text-muted font-body text-base md:text-lg max-w-xl mx-auto">
        Tout ce qu'il faut savoir pour s'assurer quand on est malussé, résilié ou en situation difficile.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-muted font-body text-lg">Aucun article pour le moment. Revenez bientot !</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a
              href={`/blog/${post.data.slug}/`}
              class="group flex flex-col bg-white border border-border rounded-2xl overflow-hidden hover:shadow-lg hover:border-orange-200 transition-all duration-300"
            >
              {post.data.image ? (
                <div class="aspect-[16/9] overflow-hidden bg-surface">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="aspect-[16/9] bg-gradient-to-br from-orange-50 to-orange-100 flex items-center justify-center">
                  <span class="text-4xl">📄</span>
                </div>
              )}
              <div class="flex flex-col flex-1 p-5">
                <div class="flex items-center gap-2 mb-3">
                  <span class="inline-block px-2.5 py-0.5 rounded-full bg-orange-100 text-orange-700 text-xs font-display font-bold">
                    {post.data.category}
                  </span>
                  {post.data.readingTime && (
                    <span class="text-xs text-muted font-body">{post.data.readingTime} min de lecture</span>
                  )}
                </div>
                <h2 class="font-display font-bold text-ink text-lg leading-snug group-hover:text-orange-500 transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-muted text-sm font-body line-clamp-2 flex-1">
                  {post.data.description}
                </p>
                <time
                  datetime={post.data.date.toISOString().slice(0, 10)}
                  class="mt-4 text-xs text-muted font-body"
                >
                  {formatDate(post.data.date)}
                </time>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-ink py-12 md:py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-black text-2xl md:text-3xl text-white">
        Besoin d'un devis ?
      </h2>
      <p class="mt-3 text-white/70 font-body">
        Malussé, résilié, permis suspendu : obtenez votre devis gratuit en ligne.
      </p>
      <a
        href="/devis/"
        class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-full bg-orange-500 text-white font-display font-bold hover:bg-orange-600 transition-colors"
      >
        Demander un devis
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-border bg-white py-8">
    <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted font-body">
      <div class="flex items-center gap-2">
        <span class="font-display font-black text-ink text-sm">{SITE.name}</span>
        <span>&middot;</span>
        <span>SIREN {SITE.siren}</span>
        <span>&middot;</span>
        <span>ORIAS {SITE.orias}</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/mentions-legales/" class="hover:text-ink transition-colors">Mentions légales</a>
        <a href="/" class="hover:text-ink transition-colors">Accueil</a>
        <a href="/devis/" class="hover:text-ink transition-colors">Devis</a>
      </div>
    </div>
  </footer>

</Base>
