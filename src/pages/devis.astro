---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/config';
import DevisAutoForm from '../components/DevisAutoForm';
---

<Base
  title={`Devis assurance auto malussé et résilié | ${SITE.name}`}
  description="Devis gratuit en ligne pour conducteurs malussés et résiliés. Particuliers et professionnels. Réponse en 24h."
  canonical={`${SITE.url}/devis`}
>

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-border">
    <div class="max-w-5xl mx-auto flex items-center justify-between px-6 h-14">
      <a href="/" class="font-display font-black text-xl text-ink tracking-tight">
        allo<span class="text-brand">malus</span>
      </a>
      <a href="/" class="text-sm text-muted hover:text-ink transition-colors">&larr; Retour</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-white py-12 md:py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h1 class="font-display text-3xl md:text-4xl font-black tracking-[-1.5px] text-ink leading-tight">
        Votre devis auto <span class="text-brand">malus</span>
      </h1>
      <p class="mt-3 text-muted text-base md:text-lg max-w-lg mx-auto">
        Malussé, résilié, permis suspendu : remplissez le formulaire, on s'occupe du reste. Réponse sous 24h.
      </p>
    </div>
  </section>

  <!-- Netlify hidden form for bot detection -->
  <form name="devis-auto" netlify netlify-honeypot="bot-field" hidden>
    <input name="profil" /><input name="usage" /><input name="formule" /><input name="coef" />
    <input name="vehicule-marque" /><input name="vehicule-modele" /><input name="vehicule-annee" /><input name="vehicule-immat" />
    <input name="conducteur-nom" /><input name="conducteur-prenom" /><input name="conducteur-email" /><input name="conducteur-telephone" />
    <input name="conducteur-naissance" /><input name="conducteur-permis" />
  </form>

  <!-- Form -->
  <section class="bg-surface py-10 md:py-14">
    <div class="max-w-2xl mx-auto px-6">
      <DevisAutoForm client:visible />
    </div>
  </section>

  <!-- Trust badges -->
  <section class="border-t border-border bg-white py-10">
    <div class="max-w-3xl mx-auto px-6 grid grid-cols-3 gap-6 text-center">
      <div>
        <div class="w-10 h-10 rounded-full bg-brand-pale flex items-center justify-center mx-auto mb-2">
          <span class="text-brand text-lg">🛡️</span>
        </div>
        <p class="font-display font-bold text-ink text-sm">ORIAS</p>
        <p class="text-xs text-muted">n° {SITE.orias}</p>
      </div>
      <div>
        <div class="w-10 h-10 rounded-full bg-brand-pale flex items-center justify-center mx-auto mb-2">
          <span class="text-brand text-lg">✓</span>
        </div>
        <p class="font-display font-bold text-ink text-sm">Devis gratuit</p>
        <p class="text-xs text-muted">Sans engagement</p>
      </div>
      <div>
        <div class="w-10 h-10 rounded-full bg-brand-pale flex items-center justify-center mx-auto mb-2">
          <span class="text-brand text-lg">⚡</span>
        </div>
        <p class="font-display font-bold text-ink text-sm">Réponse 24h</p>
        <p class="text-xs text-muted">7j/7</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-border bg-white py-8">
    <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted">
      <div class="font-display font-black text-ink text-sm">allo<span class="text-brand">malus</span></div>
      <div class="flex items-center gap-4">
        <a href="/mentions-legales/" class="hover:text-ink transition-colors">Mentions légales</a>
        <a href="/" class="hover:text-ink transition-colors">Accueil</a>
      </div>
      <span>ORIAS {SITE.orias} · SIREN {SITE.siren}</span>
    </div>
  </footer>
</Base>
