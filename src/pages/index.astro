---
import Base from '../layouts/Base.astro';
import { SITE, PROFILS, FAQ_ITEMS } from '../data/config';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_ITEMS.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<Base>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>

  <!-- ====== NAVBAR ====== -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-border">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="font-display text-xl font-black tracking-tight text-ink">allo<span class="text-brand">malus</span></a>
      <div class="hidden sm:flex items-center gap-6">
        <a href="#profils" class="text-sm text-muted hover:text-ink transition-colors">Profils</a>
        <a href="#etapes" class="text-sm text-muted hover:text-ink transition-colors">Comment ça marche</a>
        <a href="#faq" class="text-sm text-muted hover:text-ink transition-colors">FAQ</a>
        <a href="/blog/" class="text-sm text-muted hover:text-ink transition-colors">Blog</a>
      </div>
      <a href="/devis/" class="bg-ink text-white rounded-lg px-5 py-2 font-bold text-sm hover:bg-ink/80 transition-colors">
        Devis gratuit
      </a>
    </div>
  </nav>

  <!-- ====== HERO ====== -->
  <section class="bg-white pt-20 pb-24 lg:pt-28 lg:pb-32 relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 border border-border bg-surface px-4 py-1.5 rounded-full text-xs font-bold text-muted mb-8 anim-up">
          🚗 Assurance auto risques aggravés
        </div>

        <h1 class="font-display text-[clamp(40px,6vw,76px)] font-black leading-[0.9] tracking-[-3px] text-ink mb-6 anim-up d1">
          Assurance auto<br/><span class="text-brand">malus</span> et <span class="text-brand">résilié</span>.
        </h1>

        <p class="text-lg text-muted leading-relaxed max-w-lg mx-auto mb-10 anim-up d2">
          Malussé, résilié, permis suspendu, alcoolémie. On vous assure quand les autres refusent. Réponse en 24h.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4 mb-10 anim-up d3">
          <a href="/devis/" class="group inline-flex items-center justify-center gap-3 bg-ink text-white font-bold text-base px-8 py-4 rounded-lg hover:bg-ink/80 transition-all">
            Obtenir mon devis gratuit
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Social proof -->
        <div class="flex items-center justify-center gap-3 text-sm text-muted anim-up d4">
          <div class="flex -space-x-2">
            {['K','S','D','F','M'].map((l, i) => (
              <span class={`w-8 h-8 rounded-full border-2 border-white flex items-center justify-center text-[10px] font-bold text-white ${['bg-brand','bg-brand-dark','bg-emerald-600','bg-teal-600','bg-green-700'][i]}`}>{l}</span>
            ))}
          </div>
          <span><strong class="text-ink">+850</strong> conducteurs assurés</span>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-4 gap-px bg-border rounded-xl overflow-hidden mt-16 max-w-2xl mx-auto anim-up d4">
        {[
          ['<24h', 'Réponse'],
          ['100%', 'Acceptation'],
          ['850+', 'Assurés'],
          ['10 ans', 'Expérience'],
        ].map(([val, label]) => (
          <div class="bg-white py-6 text-center">
            <div class="font-display text-2xl font-black text-ink">{val}</div>
            <div class="text-[10px] text-muted uppercase tracking-[1.5px] font-bold mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== TICKER ====== -->
  <div class="bg-ink text-white/40 py-3 overflow-hidden">
    <div class="flex gap-12 animate-[scroll_20s_linear_infinite] w-max text-xs font-bold uppercase tracking-[2px]">
      {[...Array(3)].map(() => (
        <span class="flex items-center gap-8">
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand"></span>Malussé</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand"></span>Résilié</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand"></span>Permis suspendu</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand"></span>Alcoolémie</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand"></span>Jeune conducteur</span>
          <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand"></span>Véhicule pro</span>
        </span>
      ))}
    </div>
  </div>

  <!-- ====== PROFILS ====== -->
  <section id="profils" class="bg-white py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Profils</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.9] text-ink mb-14">
        Votre <span class="text-brand">profil auto</span>.<br/>Notre spécialité.
      </h2>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
        {PROFILS.map(p => (
          <a href="/devis/" class="group border border-border rounded-xl p-6 hover:border-brand transition-all block">
            <span class="text-3xl block mb-3">{p.emoji}</span>
            <h3 class="font-display text-base font-bold text-ink">{p.label}</h3>
            <p class="text-sm text-muted mt-1">{p.desc}</p>
            <span class="text-brand text-sm font-bold mt-3 block opacity-0 group-hover:opacity-100 transition-opacity">Devis gratuit &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== ETAPES ====== -->
  <section id="etapes" class="bg-surface py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Processus</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.9] text-ink mb-14">
        <span class="text-brand">Simple</span>. <span class="text-brand">Rapide</span>. <span class="text-brand">Efficace</span>.
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          ['01','📋','Votre demande','Profil, véhicule, historique. Quelques minutes depuis votre téléphone.'],
          ['02','🔍','Notre analyse','Nos experts consultent nos assureurs partenaires pour votre profil.'],
          ['03','📩','Votre offre','Une ou plusieurs propositions adaptées dans votre boite mail sous 24h.'],
          ['04','🚗','Vous roulez','Vous signez en ligne. Carte verte immédiate.'],
        ].map(([n, ico, title, desc]) => (
          <div class="bg-white border border-border rounded-xl p-7">
            <span class="font-display text-4xl font-black text-brand/20 block mb-3">{n}</span>
            <span class="text-2xl block mb-3">{ico}</span>
            <h3 class="font-display text-base font-bold text-ink mb-2">{title}</h3>
            <p class="text-sm text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-14">
        <a href="/devis/" class="inline-flex items-center gap-3 bg-ink text-white font-bold text-base px-8 py-4 rounded-lg hover:bg-ink/80 transition-all">
          Commencer maintenant &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ====== TEMOIGNAGES ====== -->
  <section class="bg-white py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Avis</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.9] text-ink mb-14">
        Ils étaient dans <span class="text-brand">l'impasse</span>.
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          ['"Après 3 refus, Allomalus m\'a trouvé une offre en 48h."','Karim B.','Malussé 1.75'],
          ['"Résiliée après un accident. Ici, pas de jugement. Juste une solution."','Sophie M.','Résiliée'],
          ['"Suspension de permis. A la récupération, impossible de m\'assurer ailleurs."','David T.','Suspendu'],
          ['"Permis depuis 2 ans, déjà un malus. Personne ne voulait de moi."','Fatima L.','Jeune conductrice'],
          ['"Utilitaire résilié. Devis le lendemain, couvert dans la semaine."','Stéphane R.','Artisan BTP'],
        ].map(([txt, name, profil]) => (
          <div class="border border-border rounded-xl p-6 hover:border-brand/30 transition-colors">
            <div class="text-brand text-xs tracking-[3px] mb-4">★★★★★</div>
            <p class="text-sm text-ink leading-relaxed mb-5">{txt}</p>
            <p class="text-sm font-bold text-ink">{name}</p>
            <p class="text-xs text-muted">{profil}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== COMPARATIF ====== -->
  <section class="bg-surface py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Pourquoi nous</p>
        <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] text-ink">
          <span class="text-brand">Allomalus</span> vs les autres.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-white border border-border rounded-xl p-8">
          <p class="text-xs font-bold uppercase tracking-[2px] text-muted mb-6">Assureur classique</p>
          {['Réponse en 5 a 10 jours','Profils refusés fréquemment','Suivi standardisé','Déplacement en agence','Vous gérez les sinistres seul'].map(f => (
            <p class="text-sm py-2 flex items-center gap-3 text-muted">
              <span class="text-red-400">✗</span>{f}
            </p>
          ))}
        </div>
        <div class="bg-white border-2 border-brand rounded-xl p-8">
          <p class="text-xs font-bold uppercase tracking-[2px] text-brand mb-6">Allomalus</p>
          {['Réponse en moins de 24h','Tous les profils acceptés','Expert dédié a votre dossier','100% en ligne','On gère les sinistres pour vous'].map(f => (
            <p class="text-sm py-2 flex items-center gap-3 text-ink">
              <span class="text-brand font-bold">✓</span>{f}
            </p>
          ))}
          <a href="/devis/" class="block mt-6 w-full py-3 rounded-lg bg-ink text-white text-center font-bold text-sm hover:bg-ink/80 transition-all">
            Obtenir mon devis &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section id="faq" class="bg-white py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">FAQ</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] text-ink mb-14">
        Vos <span class="text-brand">questions</span>.
      </h2>
      <div class="space-y-2">
        {FAQ_ITEMS.map(item => (
          <details class="group border border-border rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-bold text-ink hover:text-brand transition-colors">
              {item.q}
              <svg class="w-4 h-4 text-muted shrink-0 ml-4 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
            </summary>
            <div class="px-5 pb-5 text-sm text-muted leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FINAL CTA ====== -->
  <section class="bg-ink py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-[clamp(32px,5vw,52px)] font-black tracking-[-3px] leading-[0.9] text-white mb-6">
        Prêt a reprendre la <span class="text-brand">route</span> ?
      </h2>
      <p class="text-white/50 text-lg max-w-md mx-auto mb-10">Peu importe votre situation. On trouve une assurance auto. Toujours.</p>
      <a href="/devis/" class="inline-flex items-center gap-3 bg-brand text-ink font-bold text-lg px-10 py-5 rounded-lg hover:bg-brand-light transition-all">
        Obtenir mon devis gratuit &rarr;
      </a>
    </div>
  </section>

  <!-- ====== PARTENAIRES + FOOTER ====== -->
  <footer class="bg-white border-t border-border py-10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-wrap justify-center gap-6 text-sm text-muted mb-8">
        <a href="https://prossur.fr" target="_blank" rel="noopener" class="hover:text-brand transition-colors">Prossur - Décennale BTP</a>
        <span class="text-border">|</span>
        <a href="https://formacourtage.fr" target="_blank" rel="noopener" class="hover:text-brand transition-colors">FormaCourtage</a>
        <span class="text-border">|</span>
        <a href="https://trefle-assurance.fr" target="_blank" rel="noopener" class="hover:text-brand transition-colors">Trefle Assurance</a>
      </div>
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-6 border-t border-border">
        <div class="font-display text-lg font-black text-ink">allo<span class="text-brand">malus</span></div>
        <div class="flex gap-5 text-sm text-muted">
          <a href="/mentions-legales/" class="hover:text-ink transition-colors">Mentions légales</a>
          <a href="/devis/" class="hover:text-ink transition-colors">Devis</a>
          <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
        </div>
        <p class="text-xs text-muted">ORIAS {SITE.orias} · SIREN {SITE.siren}</p>
      </div>
    </div>
  </footer>

  <!-- ====== MOBILE STICKY CTA ====== -->
  <div class="fixed bottom-0 left-0 right-0 z-40 sm:hidden p-3 bg-white/95 backdrop-blur-lg border-t border-border">
    <a href="/devis/" class="block w-full py-3.5 bg-ink text-white text-center font-bold text-sm rounded-lg">
      Mon devis gratuit &rarr;
    </a>
  </div>

  <style>
    @keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-33.33%)} }
    @keyframes up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
    .anim-up { animation: up 0.7s cubic-bezier(0.16,1,0.3,1) forwards; opacity: 0; }
    .d1 { animation-delay: 0.12s; }
    .d2 { animation-delay: 0.24s; }
    .d3 { animation-delay: 0.36s; }
    .d4 { animation-delay: 0.48s; }
  </style>
</Base>
