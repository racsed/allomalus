---
import Base from '../layouts/Base.astro';
import { SITE, PROFILS, FAQ_ITEMS } from '../data/config';

const steps = [
  { num: '01', title: 'Formulaire', desc: 'Remplissez votre demande en 2 minutes. Profil, vehicule, historique.', icon: '📋' },
  { num: '02', title: 'Analyse', desc: 'Nos experts etudient votre dossier et consultent nos partenaires assureurs.', icon: '🔍' },
  { num: '03', title: 'Devis', desc: 'Vous recevez une ou plusieurs propositions sous 24h.', icon: '📩' },
  { num: '04', title: 'Couvert', desc: 'Vous choisissez, vous signez, vous roulez. Simple.', icon: '✅' },
];

const guarantees = [
  { name: 'Tiers', price: 'Dès 45€/mois', features: ['Responsabilité civile', 'Défense pénale', 'Assistance panne 0 km', 'Protection juridique'], highlight: false },
  { name: 'Tiers+', price: 'Dès 65€/mois', features: ['Tout Tiers inclus', 'Vol & tentative de vol', 'Incendie & explosion', 'Bris de glace', 'Catastrophes naturelles'], highlight: true },
  { name: 'Tous risques', price: 'Dès 90€/mois', features: ['Tout Tiers+ inclus', 'Dommages tous accidents', 'Valeur à neuf 1 an', 'Véhicule de remplacement', 'Contenu du véhicule'], highlight: false },
];

const reviews = [
  { name: 'Karim B.', profil: 'Malussé 1.75', text: "Après 3 refus d'assureurs, Allomalus m'a trouvé une offre en 48h. Le tarif est correct et le service au top.", rating: 5 },
  { name: 'Sophie M.', profil: 'Résiliée', text: "Mon assureur m'a résiliée après un accident responsable. Allomalus a repris mon dossier sans jugement. Je recommande.", rating: 5 },
  { name: 'David T.', profil: 'Permis suspendu', text: "Suspension de 6 mois pour excès de vitesse. A la récupération du permis, impossible de m'assurer. Sauf ici.", rating: 5 },
  { name: 'Fatima L.', profil: 'Jeune conductrice malussée', text: "Permis depuis 2 ans et déjà un malus. Personne ne voulait m'assurer à un prix décent. Allomalus a fait la différence.", rating: 4 },
  { name: 'Stéphane R.', profil: 'Artisan BTP, résilié', text: "Mon utilitaire résilié, c'était la galère pour bosser. Devis reçu le lendemain, couvert dans la semaine. Sérieux.", rating: 5 },
];

const comparisons = [
  { label: 'Frais de dossier', them: '150-300€', us: '0€' },
  { label: 'Délai de réponse', them: '5-10 jours', us: 'Moins de 24h' },
  { label: 'Profils refusés', them: 'Fréquent', us: 'Aucun refus' },
  { label: 'Suivi personnalisé', them: 'Bot / standard', us: 'Expert dédié' },
  { label: 'Démarche', them: 'Agence physique', us: '100% en ligne' },
  { label: 'Transparence tarif', them: 'Opaque', us: 'Devis détaillé' },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_ITEMS.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<Base>
  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>

  <style>
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .marquee-track {
      animation: scroll 20s linear infinite;
    }
    .marquee-track:hover {
      animation-play-state: paused;
    }
    details[open] summary .faq-chevron {
      transform: rotate(180deg);
    }
    .faq-chevron {
      transition: transform 0.2s ease;
    }
  </style>

  <!-- ============ MARQUEE ============ -->
  <div class="bg-ink text-white/80 text-sm font-body overflow-hidden py-2 select-none">
    <div class="marquee-track flex whitespace-nowrap w-max">
      {[...Array(2)].map(() => (
        <span class="flex items-center gap-8 px-4">
          <span class="flex items-center gap-2">📉 Malussé</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">❌ Résilié</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🚫 Permis suspendu</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🍷 Alcoolémie</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🔰 Jeune conducteur</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🚐 Pro &amp; utilitaire</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">📉 Malussé</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">❌ Résilié</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🚫 Permis suspendu</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🍷 Alcoolémie</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🔰 Jeune conducteur</span>
          <span class="text-white/30">-</span>
          <span class="flex items-center gap-2">🚐 Pro &amp; utilitaire</span>
          <span class="text-white/30 pr-8">-</span>
        </span>
      ))}
    </div>
  </div>

  <!-- ============ NAVBAR ============ -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-lg border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
      <a href="/" class="font-display font-bold text-2xl text-ink tracking-tight">allomalus<span class="text-brand">.</span></a>
      <div class="hidden md:flex items-center gap-8 text-sm font-body font-medium text-muted">
        <a href="#profils" class="hover:text-ink transition-colors">Profils</a>
        <a href="#garanties" class="hover:text-ink transition-colors">Tarifs</a>
        <a href="#faq" class="hover:text-ink transition-colors">FAQ</a>
        <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
      </div>
      <a href="/devis/" class="hidden sm:inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white text-sm font-display font-bold px-5 py-2.5 rounded-full transition-all hover:shadow-lift">
        Mon devis gratuit
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </nav>

  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-pale to-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white border border-border rounded-full px-4 py-1.5 text-sm text-muted font-body shadow-soft mb-6">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Réponse en 24h - 100% en ligne
        </div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl leading-[1.1] text-ink mb-6">
          Votre auto <span class="font-serif italic text-brand">assurée</span>,<br/>même avec un malus.
        </h1>
        <p class="text-lg sm:text-xl text-muted font-body leading-relaxed max-w-xl mb-8">
          Malussé, résilié, permis suspendu : on trouve votre assurance auto. Devis en 2 min, réponse sous 24h.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/devis/" class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-dark text-white font-display font-bold text-lg px-8 py-4 rounded-full transition-all hover:shadow-lift hover:-translate-y-0.5">
            Obtenir mon devis gratuit
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href={"tel:" + SITE.phone.replace(/\s/g, '')} class="inline-flex items-center justify-center gap-2 bg-white hover:bg-surface border border-border text-ink font-display font-bold text-lg px-8 py-4 rounded-full transition-all hover:shadow-soft">
            📞 {SITE.phone}
          </a>
        </div>
      </div>
      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { value: '0€', label: 'Frais de dossier' },
          { value: '<24h', label: 'Délai de réponse' },
          { value: '100%', label: 'En ligne' },
          { value: '10+', label: "Ans d'expérience" },
        ].map(stat => (
          <div class="bg-white rounded-2xl border border-border p-5 text-center shadow-soft">
            <div class="font-display font-bold text-2xl sm:text-3xl text-brand">{stat.value}</div>
            <div class="text-sm text-muted font-body mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PROFILS ============ -->
  <section id="profils" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block bg-brand-pale text-brand text-sm font-body font-medium px-4 py-1 rounded-full mb-4">Votre profil</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-ink">On assure <span class="font-serif italic">tous</span> les profils</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {PROFILS.map(p => (
          <a href="/devis/" class="group bg-white border border-border rounded-2xl p-6 hover:shadow-lift hover:-translate-y-1 transition-all duration-300">
            <div class="text-3xl mb-3">{p.emoji}</div>
            <h3 class="font-display font-bold text-lg text-ink group-hover:text-brand transition-colors">{p.label}</h3>
            <p class="text-sm text-muted font-body mt-1 leading-relaxed">{p.desc}</p>
            <div class="mt-4 text-brand text-sm font-display font-bold flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              Demander un devis
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block bg-accent-pale text-accent text-sm font-body font-medium px-4 py-1 rounded-full mb-4">Simple et rapide</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-ink">Comment ça <span class="font-serif italic">marche</span> ?</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map((s, i) => (
          <div class="relative bg-white rounded-2xl p-6 shadow-soft">
            <div class="font-display font-bold text-5xl text-brand/10 absolute top-4 right-4">{s.num}</div>
            <div class="text-3xl mb-4">{s.icon}</div>
            <h3 class="font-display font-bold text-lg text-ink mb-2">{s.title}</h3>
            <p class="text-sm text-muted font-body leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ GUARANTEES ============ -->
  <section id="garanties" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block bg-brand-pale text-brand text-sm font-body font-medium px-4 py-1 rounded-full mb-4">Nos formules</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-ink">Choisissez votre <span class="font-serif italic">couverture</span></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {guarantees.map(g => (
          <div class:list={["rounded-2xl p-7 border-2 transition-all hover:-translate-y-1 hover:shadow-lift", g.highlight ? 'border-brand bg-brand-pale relative' : 'border-border bg-white']}>
            {g.highlight && <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand text-white text-xs font-display font-bold px-4 py-1 rounded-full">Populaire</div>}
            <h3 class="font-display font-bold text-xl text-ink mb-1">{g.name}</h3>
            <div class="font-display font-bold text-2xl text-brand mb-5">{g.price}</div>
            <ul class="space-y-3 mb-6">
              {g.features.map(f => (
                <li class="flex items-start gap-2 text-sm font-body text-muted">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/devis/" class:list={["block text-center font-display font-bold text-sm px-6 py-3 rounded-full transition-all", g.highlight ? 'bg-brand text-white hover:bg-brand-dark hover:shadow-lift' : 'bg-surface text-ink hover:bg-brand hover:text-white']}>
              Demander un devis
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ REVIEWS ============ -->
  <section class="py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block bg-accent-pale text-accent text-sm font-body font-medium px-4 py-1 rounded-full mb-4">Témoignages</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-ink">Ils nous ont fait <span class="font-serif italic">confiance</span></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {reviews.map(r => (
          <div class="bg-white rounded-2xl p-6 shadow-soft border border-border">
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: 5 }, (_, i) => (
                <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-4 h-4", i < r.rating ? 'text-brand' : 'text-border']} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-sm text-ink font-body leading-relaxed mb-4">"{r.text}"</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-brand-pale flex items-center justify-center font-display font-bold text-brand text-sm">{r.name.charAt(0)}</div>
              <div>
                <div class="font-display font-bold text-sm text-ink">{r.name}</div>
                <div class="text-xs text-muted font-body">{r.profil}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PRICING COMPARISON ============ -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block bg-brand-pale text-brand text-sm font-body font-medium px-4 py-1 rounded-full mb-4">Comparez</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-ink">Assureur classique vs <span class="font-serif italic text-brand">Allomalus</span></h2>
      </div>
      <div class="rounded-2xl border border-border overflow-hidden shadow-soft">
        <div class="grid grid-cols-3 bg-surface text-sm font-display font-bold text-muted border-b border-border">
          <div class="p-4"></div>
          <div class="p-4 text-center">Ailleurs</div>
          <div class="p-4 text-center text-brand bg-brand-pale">Allomalus</div>
        </div>
        {comparisons.map((c, i) => (
          <div class:list={["grid grid-cols-3 text-sm font-body", i < comparisons.length - 1 ? 'border-b border-border' : '']}>
            <div class="p-4 font-medium text-ink">{c.label}</div>
            <div class="p-4 text-center text-muted">{c.them}</div>
            <div class="p-4 text-center font-bold text-brand bg-brand-pale/50">{c.us}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section id="faq" class="py-20 bg-surface">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block bg-accent-pale text-accent text-sm font-body font-medium px-4 py-1 rounded-full mb-4">FAQ</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-ink">Questions <span class="font-serif italic">fréquentes</span></h2>
      </div>
      <div class="space-y-3">
        {FAQ_ITEMS.map(item => (
          <details class="group bg-white rounded-2xl border border-border shadow-soft">
            <summary class="flex items-center justify-between cursor-pointer p-5 font-display font-bold text-ink text-sm sm:text-base list-none [&::-webkit-details-marker]:hidden">
              {item.q}
              <svg xmlns="http://www.w3.org/2000/svg" class="faq-chevron w-5 h-5 text-muted flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-5 text-sm text-muted font-body leading-relaxed border-t border-border pt-4">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ BOTTOM CTA ============ -->
  <section class="py-20 bg-ink">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">Prêt à être <span class="font-serif italic text-brand">couvert</span> ?</h2>
      <p class="text-lg text-white/60 font-body mb-8 max-w-lg mx-auto">Malussé, résilié, permis suspendu : peu importe votre situation, on a une solution. Devis gratuit, sans engagement.</p>
      <a href="/devis/" class="inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white font-display font-bold text-lg px-10 py-4 rounded-full transition-all hover:shadow-lift hover:-translate-y-0.5">
        Obtenir mon devis gratuit
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  <!-- ============ INTERNAL LINKING ============ -->
  <section class="py-16 bg-white border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-border p-6 hover:shadow-soft transition-all">
          <h3 class="font-display font-bold text-lg text-ink mb-2">Nos guides assurance</h3>
          <p class="text-sm text-muted font-body mb-3">Malus, résiliation, bonus-malus : tout comprendre sur l'assurance auto en France.</p>
          <a href="/blog/" class="text-brand text-sm font-display font-bold hover:underline">Lire le blog &rarr;</a>
        </div>
        <a href="https://prossur.fr" target="_blank" rel="noopener" class="rounded-2xl border border-border p-6 hover:shadow-soft transition-all group">
          <h3 class="font-display font-bold text-lg text-ink mb-2 group-hover:text-brand transition-colors">Besoin d'une décennale BTP ?</h3>
          <p class="text-sm text-muted font-body mb-3">Prossur, notre partenaire courtier, assure les pros du bâtiment : RC décennale, RC pro, multirisque.</p>
          <span class="text-brand text-sm font-display font-bold">Découvrir Prossur &rarr;</span>
        </a>
        <a href="https://formacourtage.fr" target="_blank" rel="noopener" class="rounded-2xl border border-border p-6 hover:shadow-soft transition-all group">
          <h3 class="font-display font-bold text-lg text-ink mb-2 group-hover:text-brand transition-colors">Devenir courtier en assurance ?</h3>
          <p class="text-sm text-muted font-body mb-3">FormaCourtage propose la formation IAS 150h pour obtenir votre capacité professionnelle.</p>
          <span class="text-brand text-sm font-display font-bold">Découvrir FormaCourtage &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="bg-ink text-white/60 pt-16 pb-28 md:pb-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-4 gap-10 mb-12">
        <div class="md:col-span-1">
          <a href="/" class="font-display font-bold text-2xl text-white tracking-tight">allomalus<span class="text-brand">.</span></a>
          <p class="text-sm mt-3 leading-relaxed">Courtier spécialisé en assurance auto pour conducteurs malussés et résiliés. Particuliers et professionnels.</p>
        </div>
        <div>
          <h4 class="font-display font-bold text-white text-sm mb-4">Navigation</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="#profils" class="hover:text-white transition-colors">Nos profils</a></li>
            <li><a href="#garanties" class="hover:text-white transition-colors">Tarifs &amp; garanties</a></li>
            <li><a href="#faq" class="hover:text-white transition-colors">FAQ</a></li>
            <li><a href="/blog/" class="hover:text-white transition-colors">Blog</a></li>
            <li><a href="/devis/" class="hover:text-white transition-colors">Demander un devis</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-display font-bold text-white text-sm mb-4">Légal</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/mentions-legales/" class="hover:text-white transition-colors">Mentions légales</a></li>
            <li><a href="/politique-confidentialite/" class="hover:text-white transition-colors">Politique de confidentialité</a></li>
            <li><a href="/cgv/" class="hover:text-white transition-colors">CGV</a></li>
          </ul>
        </div>
