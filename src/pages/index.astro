---
import Base from '../layouts/Base.astro';
import { SITE, PROFILS, FAQ_ITEMS } from '../data/config';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_ITEMS.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<Base>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>

  <!-- ====== MARQUEE ====== -->
  <div class="overflow-hidden bg-ink py-2.5">
    <div class="flex gap-10 animate-[scroll_25s_linear_infinite] w-max">
      {[...PROFILS, ...PROFILS, ...PROFILS].map(p => (
        <span class="text-xs font-bold text-white/25 uppercase tracking-[2px] whitespace-nowrap flex items-center gap-2.5">
          <span class="w-1.5 h-1.5 rounded-full bg-brand"></span>{p.label}
        </span>
      ))}
    </div>
  </div>

  <!-- ====== NAVBAR ====== -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-border/50">
    <div class="max-w-6xl mx-auto px-6 sm:px-10 lg:px-16 flex items-center justify-between h-16">
      <a href="/" class="font-display text-2xl font-black tracking-tight text-ink">allo<span class="text-brand">malus</span><span class="text-brand">.</span></a>
      <div class="hidden sm:flex items-center gap-7">
        <a href="#profils" class="text-sm text-muted hover:text-brand transition-colors">Profils</a>
        <a href="#formules" class="text-sm text-muted hover:text-brand transition-colors">Formules</a>
        <a href="#faq" class="text-sm text-muted hover:text-brand transition-colors">FAQ</a>
        <a href="/blog/" class="text-sm text-muted hover:text-brand transition-colors">Blog</a>
      </div>
      <a href="/devis/" class="bg-brand text-white rounded-full px-6 py-2.5 font-bold text-sm tracking-wide hover:-translate-y-1 hover:shadow-lift transition-all hidden sm:inline-flex">
        Mon devis gratuit &rarr;
      </a>
    </div>
  </nav>

  <!-- ====== HERO ====== -->
  <section class="relative overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-ink via-ink to-brand/20"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(16,185,129,0.15),_transparent_70%)]"></div>

    <div class="relative max-w-3xl mx-auto px-6 text-center py-20 lg:py-32">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white/80 px-4 py-2 rounded-full text-xs font-extrabold uppercase tracking-[1.5px] mb-8 border border-white/10">
        <span class="w-2 h-2 rounded-full bg-brand animate-pulse"></span>
        Réponse en 24h
      </div>

      <!-- H1 -->
      <h1 class="font-display text-[clamp(36px,5.5vw,64px)] font-black leading-[0.95] tracking-[-2.5px] mb-6 text-white">
        Votre auto assurée,<br/>
        <span class="font-serif italic font-normal text-brand">même avec un malus.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg text-white/60 leading-relaxed max-w-xl mx-auto mb-10">
        Malussé, résilié, permis suspendu : on trouve votre assurance auto quand les autres refusent. Particuliers et professionnels.
      </p>

      <!-- CTA -->
      <a href="/devis/" class="inline-flex items-center gap-2 bg-brand text-white text-lg px-10 py-5 rounded-full shadow-soft tracking-wide hover:-translate-y-1 hover:shadow-lift transition-all font-bold">
        Obtenir mon devis gratuit &rarr;
      </a>
      <p class="text-white/30 text-sm mt-4">Gratuit, sans engagement, 2 minutes</p>

      <!-- Stats -->
      <div class="flex justify-center gap-10 sm:gap-16 flex-wrap mt-14">
        {[['0€','Frais de dossier'],['<24h','Réponse'],['100%','En ligne'],['10+','Ans d\'expérience']].map(([val, label]) => (
          <div class="text-center">
            <div class="font-display text-3xl font-black tracking-tight"><span class="text-brand" set:html={val}></span></div>
            <div class="text-xs text-white/40 uppercase tracking-[1.5px] font-bold mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== TRUST BAR ====== -->
  <div class="bg-brand-pale flex justify-center gap-10 flex-wrap py-5">
    {['🛡️ Courtier ORIAS','✓ Tous profils acceptés','🔒 Données sécurisées','⚡ Réponse 24h','📋 0 frais'].map(t => (
      <span class="text-sm font-bold text-ink/50">{t}</span>
    ))}
  </div>

  <!-- ====== PROFILS ====== -->
  <section id="profils" class="bg-white py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs font-extrabold uppercase tracking-[3px] text-brand mb-4">Votre situation</p>
        <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.95] text-ink">On assure <span class="font-serif italic font-normal text-brand">tous</span> les profils</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {PROFILS.map(p => (
          <a href="/devis/" class="bg-white border border-border rounded-2xl p-5 text-center hover:-translate-y-1 hover:shadow-soft hover:border-brand/30 transition-all block group">
            <span class="text-3xl block mb-3">{p.emoji}</span>
            <span class="text-sm font-semibold text-ink group-hover:text-brand transition-colors">{p.label}</span>
            <p class="text-[11px] text-muted mt-1 leading-snug">{p.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== COMMENT CA MARCHE ====== -->
  <section class="bg-surface py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-extrabold uppercase tracking-[3px] text-brand mb-4">Simple et rapide</p>
      <h2 class="font-display text-[clamp(30px,4vw,44px)] font-black tracking-[-2px] leading-[0.95] mb-3 text-ink">4 étapes. C'est tout.</h2>
      <p class="text-base text-muted max-w-md mb-12">Du formulaire a l'attestation, tout se passe en ligne.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          ['01','📋','Formulaire','Votre profil, votre véhicule, votre historique. 2 minutes, depuis votre téléphone.'],
          ['02','🔍','Analyse','Nos experts étudient votre dossier et consultent nos assureurs partenaires.'],
          ['03','📩','Proposition','Vous recevez une ou plusieurs offres adaptées a votre profil sous 24h.'],
          ['04','✅','Couvert','Vous choisissez, vous signez en ligne, vous roulez. Attestation immédiate.'],
        ].map(([n, ico, title, desc]) => (
          <div class="bg-white border border-border rounded-2xl p-7 hover:-translate-y-1 hover:shadow-soft transition-all">
            <span class="text-5xl font-black text-brand/15 tracking-[-3px] leading-none block mb-3">{n}</span>
            <span class="text-2xl block mb-3">{ico}</span>
            <h3 class="font-display text-base font-extrabold tracking-[-0.3px] mb-2 text-ink">{title}</h3>
            <p class="text-sm text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FORMULES ====== -->
  <section id="formules" class="bg-white py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs font-extrabold uppercase tracking-[3px] text-brand mb-4">Nos formules</p>
        <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.95] text-ink">La couverture qu'il vous <span class="font-serif italic font-normal text-brand">faut</span></h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5 max-w-4xl mx-auto">
        <!-- Tiers -->
        <div class="bg-white border border-border rounded-3xl p-8 hover:-translate-y-1 hover:shadow-soft transition-all">
          <p class="text-xs font-extrabold uppercase tracking-[1.5px] text-muted mb-2">Tiers</p>
          <p class="font-display text-lg font-black text-ink mb-1">Minimum légal</p>
          <p class="text-sm text-muted mb-6">L'essentiel pour rouler en règle</p>
          {['Responsabilité civile','Défense pénale','Assistance panne 0 km','Protection juridique'].map(f => (
            <p class="text-sm py-1.5 flex items-center gap-2.5 text-ink/70 font-medium">
              <span class="text-brand font-bold">✓</span>{f}
            </p>
          ))}
          <a href="/devis/" class="block mt-6 w-full py-3 rounded-full bg-surface text-ink text-center font-bold text-sm hover:bg-brand hover:text-white transition-all">
            Demander un devis
          </a>
        </div>

        <!-- Tiers+ -->
        <div class="bg-white border-2 border-brand rounded-3xl p-8 relative shadow-soft hover:-translate-y-1 hover:shadow-lift transition-all">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand text-white px-4 py-1.5 rounded-full text-[11px] font-extrabold uppercase tracking-[1px]">Le plus demandé</div>
          <p class="text-xs font-extrabold uppercase tracking-[1.5px] text-brand mb-2">Tiers +</p>
          <p class="font-display text-lg font-black text-ink mb-1">Protection étendue</p>
          <p class="text-sm text-muted mb-6">Le meilleur rapport couverture/prix</p>
          {['Tout Tiers inclus','Vol et tentative de vol','Incendie et explosion','Bris de glace','Catastrophes naturelles'].map(f => (
            <p class="text-sm py-1.5 flex items-center gap-2.5 text-ink/70 font-medium">
              <span class="text-brand font-bold">✓</span>{f}
            </p>
          ))}
          <a href="/devis/" class="block mt-6 w-full py-3 rounded-full bg-brand text-white text-center font-bold text-sm hover:-translate-y-0.5 hover:shadow-lift transition-all">
            Demander un devis &rarr;
          </a>
        </div>

        <!-- Tous risques -->
        <div class="bg-white border border-border rounded-3xl p-8 hover:-translate-y-1 hover:shadow-soft transition-all">
          <p class="text-xs font-extrabold uppercase tracking-[1.5px] text-muted mb-2">Tous risques</p>
          <p class="font-display text-lg font-black text-ink mb-1">Protection maximale</p>
          <p class="text-sm text-muted mb-6">La tranquillité totale</p>
          {['Tout Tiers+ inclus','Dommages tous accidents','Valeur a neuf 1 an','Véhicule de remplacement','Contenu du véhicule'].map(f => (
            <p class="text-sm py-1.5 flex items-center gap-2.5 text-ink/70 font-medium">
              <span class="text-brand font-bold">✓</span>{f}
            </p>
          ))}
          <a href="/devis/" class="block mt-6 w-full py-3 rounded-full bg-surface text-ink text-center font-bold text-sm hover:bg-brand hover:text-white transition-all">
            Demander un devis
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== AVIS ====== -->
  <section class="bg-surface py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-extrabold uppercase tracking-[3px] text-brand mb-4">Avis</p>
      <div class="flex items-center gap-3 mb-12">
        <h2 class="font-display text-[clamp(30px,4vw,44px)] font-black tracking-[-2px] leading-[0.95] text-ink">Ils étaient dans l'impasse.</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          ['"Après 3 refus, Allomalus m\'a trouvé une offre en 48h. Je ne pensais pas que c\'était encore possible."','Karim B.','Malussé 1.75'],
          ['"Mon assureur m\'a résiliée après un accident responsable. Allomalus a repris mon dossier sans jugement. Merci."','Sophie M.','Résiliée'],
          ['"Suspension de 6 mois pour excès de vitesse. A la récupération du permis, impossible de m\'assurer. Sauf ici."','David T.','Permis suspendu'],
          ['"Permis depuis 2 ans et déjà un malus. Personne ne voulait de moi. Allomalus a trouvé une solution correcte."','Fatima L.','Jeune conductrice'],
          ['"Mon utilitaire résilié, c\'était la galère pour bosser. Devis reçu le lendemain, couvert dans la semaine."','Stéphane R.','Artisan BTP'],
        ].map(([txt, name, profil]) => (
          <div class="bg-white border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-soft hover:border-brand/20 transition-all group">
            <div class="text-brand text-sm tracking-[2px] mb-3">★★★★★</div>
            <p class="text-sm text-ink leading-relaxed mb-4 font-medium">{txt}</p>
            <div class="flex items-center gap-3">
              <span class="w-9 h-9 rounded-full bg-brand-pale flex items-center justify-center text-[11px] font-bold text-brand">{name.charAt(0)}{name.split(' ')[1]?.charAt(0)}</span>
              <div>
                <p class="text-sm text-ink font-semibold group-hover:text-brand transition-colors">{name}</p>
                <p class="text-xs text-muted">{profil}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== COMPARATIF ====== -->
  <section class="bg-white py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs font-extrabold uppercase tracking-[3px] text-brand mb-4">Comparatif</p>
        <h2 class="font-display text-[clamp(30px,4vw,40px)] font-black text-ink tracking-[-1.5px]">Faites la différence.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-5 max-w-2xl mx-auto">
        <!-- Ailleurs -->
        <div class="bg-surface border border-border rounded-3xl p-9 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-ink/60 text-white px-4 py-1.5 rounded-full text-[11px] font-extrabold uppercase tracking-[1px]">Ailleurs</div>
          <p class="text-xs font-extrabold uppercase tracking-[1.5px] text-ink/30 mb-6">Assureur classique</p>
          {['✗ Frais de dossier','✗ Réponse en 5 a 10 jours','✗ Profils refusés fréquemment','✗ Suivi standardisé','✗ Déplacement en agence','✗ Vous gérez les sinistres seul'].map(f => (
            <p class="text-sm py-1.5 flex items-center gap-2.5 text-ink/30 font-medium">
              <span class="text-red-400 font-bold">{f.charAt(0)}</span>{f.slice(2)}
            </p>
          ))}
        </div>
        <!-- Allomalus -->
        <div class="bg-white border-2 border-brand rounded-3xl p-9 relative shadow-soft">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand text-white px-4 py-1.5 rounded-full text-[11px] font-extrabold uppercase tracking-[1px]">Allomalus</div>
          <p class="text-xs font-extrabold uppercase tracking-[1.5px] text-brand mb-6">Courtier spécialisé</p>
          {['Aucun frais de dossier','Réponse en moins de 24h','Tous les profils acceptés','Expert dédié a votre dossier','100% en ligne, depuis chez vous','On gère les sinistres pour vous'].map(f => (
            <p class="text-sm py-1.5 flex items-center gap-2.5 text-ink/70 font-medium">
              <span class="text-brand font-bold">✓</span>{f}
            </p>
          ))}
          <a href="/devis/" class="block mt-8 w-full py-4 rounded-full bg-brand text-white text-center font-bold text-base tracking-wide hover:-translate-y-1 hover:shadow-lift transition-all">
            Obtenir mon devis &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section id="faq" class="bg-surface py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-xs font-extrabold uppercase tracking-[3px] text-brand mb-4">FAQ</p>
      <h2 class="font-display text-[clamp(30px,4vw,44px)] font-black tracking-[-2px] leading-[0.95] mb-12 text-ink">Vos questions.</h2>
      <div class="space-y-3">
        {FAQ_ITEMS.map(item => (
          <details class="group border border-border rounded-2xl overflow-hidden bg-white">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-bold text-base text-ink hover:bg-surface transition-colors">
              {item.q}
              <svg class="w-5 h-5 text-ink/30 shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-6 text-[15px] text-muted leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== BOTTOM CTA ====== -->
  <section class="bg-ink py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.95] mb-5 text-white">
        Prêt a rouler <span class="font-serif italic font-normal text-brand">sereinement</span> ?
      </h2>
      <p class="text-base text-white/50 max-w-md mx-auto mb-10">Malussé, résilié, permis suspendu : peu importe votre situation. On trouve une solution. Toujours.</p>
      <a href="/devis/" class="inline-flex items-center gap-2 bg-brand text-white px-10 py-5 rounded-full font-bold text-lg tracking-wide hover:-translate-y-1 hover:shadow-lift transition-all shadow-soft">
        Obtenir mon devis gratuit &rarr;
      </a>
    </div>
  </section>

  <!-- ====== PARTENAIRES ====== -->
  <section class="bg-white py-16 lg:py-20 border-t border-border">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-extrabold uppercase tracking-[3px] text-brand mb-8">Nos partenaires</p>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="https://prossur.fr" target="_blank" rel="noopener" class="group bg-white border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-soft hover:border-brand/30 transition-all block">
          <h3 class="font-display text-base font-extrabold text-ink group-hover:text-brand transition-colors mb-2">🏗️ Décennale artisan BTP</h3>
          <p class="text-sm text-muted leading-relaxed">Prossur assure les artisans du bâtiment : décennale, RC pro, dès 69 €/mois.</p>
          <span class="text-brand text-sm font-bold mt-3 inline-block">prossur.fr &rarr;</span>
        </a>
        <a href="https://formacourtage.fr" target="_blank" rel="noopener" class="group bg-white border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-soft hover:border-brand/30 transition-all block">
          <h3 class="font-display text-base font-extrabold text-ink group-hover:text-brand transition-colors mb-2">🎓 Devenir courtier</h3>
          <p class="text-sm text-muted leading-relaxed">FormaCourtage : la formation IAS 150h pour obtenir votre capacité professionnelle.</p>
          <span class="text-brand text-sm font-bold mt-3 inline-block">formacourtage.fr &rarr;</span>
        </a>
        <a href="/blog/" class="group bg-white border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-soft hover:border-brand/30 transition-all block">
          <h3 class="font-display text-base font-extrabold text-ink group-hover:text-brand transition-colors mb-2">📖 Nos guides</h3>
          <p class="text-sm text-muted leading-relaxed">Malus, résiliation, bonus-malus : tout comprendre sur l'assurance auto.</p>
          <span class="text-brand text-sm font-bold mt-3 inline-block">Lire le blog &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ====== FOOTER ====== -->
  <footer class="bg-ink pt-14 pb-8">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <div class="font-display text-2xl font-black text-white mb-3">allo<span class="text-brand">malus</span><span class="text-brand">.</span></div>
      <p class="text-sm text-white/40 max-w-sm mx-auto leading-relaxed mb-10">Courtier spécialisé en assurance auto pour conducteurs malussés et résiliés.</p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-12 gap-y-8 max-w-2xl mx-auto pb-10 border-b border-white/10 text-left">
        <div>
          <h5 class="text-[10px] uppercase tracking-[1.5px] text-white/30 font-bold mb-4">Navigation</h5>
          <a href="#profils" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">Profils</a>
          <a href="#formules" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">Formules</a>
          <a href="#faq" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">FAQ</a>
          <a href="/blog/" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">Blog</a>
        </div>
        <div>
          <h5 class="text-[10px] uppercase tracking-[1.5px] text-white/30 font-bold mb-4">Légal</h5>
          <a href="/mentions-legales/" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">Mentions légales</a>
        </div>
        <div>
          <h5 class="text-[10px] uppercase tracking-[1.5px] text-white/30 font-bold mb-4">Partenaires</h5>
          <a href="https://prossur.fr" target="_blank" rel="noopener" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">Prossur</a>
          <a href="https://formacourtage.fr" target="_blank" rel="noopener" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">FormaCourtage</a>
          <a href="https://trefle-assurance.fr" target="_blank" rel="noopener" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">Trefle Assurance</a>
        </div>
        <div>
          <h5 class="text-[10px] uppercase tracking-[1.5px] text-white/30 font-bold mb-4">Contact</h5>
          <a href="/devis/" class="block text-sm text-white/40 mb-2 hover:text-brand transition-colors">Demander un devis</a>
        </div>
      </div>

      <p class="text-xs text-white/30 pt-5">&copy; {new Date().getFullYear()} Allomalus · SIREN {SITE.siren} · ORIAS n&deg;{SITE.orias} · Courtier en assurance</p>
    </div>
  </footer>

  <!-- ====== MOBILE STICKY CTA ====== -->
  <div class="fixed bottom-0 left-0 right-0 z-40 sm:hidden p-4 bg-gradient-to-t from-white via-white to-white/0 pointer-events-none">
    <a href="/devis/" class="pointer-events-auto block w-full py-4 bg-brand text-white text-center font-bold text-base rounded-full shadow-lift">
      Mon devis gratuit &rarr;
    </a>
  </div>

  <style>
    @keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
  </style>
</Base>
