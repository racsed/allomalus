---
import Base from '../layouts/Base.astro';
import { SITE, PROFILS, VEHICULES, FAQ_ITEMS } from '../data/config';
import AnimatedHero from '../components/AnimatedHero';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_ITEMS.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const waLink = `https://wa.me/${SITE.whatsapp.replace(/[^0-9]/g, '')}?text=${encodeURIComponent("Bonjour, je cherche une assurance auto malus. Pouvez-vous m'aider ?")}`;
---

<Base>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>

  <!-- ====== NAVBAR ====== -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-border">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="font-display text-xl font-black tracking-tight text-ink"><span class="text-brand">allomalus</span><span class="text-ink">.</span></a>
      <div class="hidden sm:flex items-center gap-6">
        <a href="#vehicules" class="text-sm text-muted hover:text-ink transition-colors">Véhicules</a>
        <a href="#profils" class="text-sm text-muted hover:text-ink transition-colors">Profils</a>
        <a href="#faq" class="text-sm text-muted hover:text-ink transition-colors">FAQ</a>
        <a href="/blog/" class="text-sm text-muted hover:text-ink transition-colors">Blog</a>
      </div>
      <a href="/devis/" class="bg-ink text-white rounded-lg px-5 py-2 font-bold text-sm hover:bg-ink/80 transition-colors">
        Devis gratuit
      </a>
    </div>
  </nav>

  <!-- ====== HERO ====== -->
  <section class="bg-white pt-16 pb-20 lg:pt-24 lg:pb-28 relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6">
      <div class="lg:grid lg:grid-cols-[1fr_380px] lg:gap-12 items-center">
        <!-- Left -->
        <div>
          <div class="inline-flex items-center gap-2 border border-brand/20 bg-brand-pale px-3 py-1.5 rounded-full text-xs font-bold text-brand mb-6 anim-up">
            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-brand"></span></span>
            Spécialiste assurance auto malus et résilié
          </div>

          <div class="mb-5 anim-up d1">
            <AnimatedHero client:visible />
          </div>

          <p class="text-lg text-muted leading-relaxed max-w-lg mb-8 anim-up d2">
            Malussé, résilié, permis suspendu, alcoolémie. On vous assure quand les autres refusent.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-8 anim-up d3">
            <a href="/devis/" class="group inline-flex items-center justify-center gap-2 bg-ink text-white font-bold text-base px-8 py-4 rounded-lg hover:bg-ink/80 transition-all">
              Obtenir mon devis gratuit
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 border border-border bg-white text-ink font-bold text-base px-6 py-4 rounded-lg hover:border-brand hover:text-brand transition-all">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </div>

          <!-- Social proof -->
          <div class="flex items-center gap-4 anim-up d4">
            <div class="flex -space-x-2">
              {['K','S','D','F','M'].map((l, i) => (
                <span class={`w-8 h-8 rounded-full border-2 border-white flex items-center justify-center text-[10px] font-bold text-white ${['bg-brand','bg-brand-dark','bg-emerald-600','bg-teal-600','bg-green-700'][i]}`}>{l}</span>
              ))}
            </div>
            <div class="text-sm text-muted">
              <strong class="text-ink">+850</strong> conducteurs assurés
              <div class="flex items-center gap-1 text-brand text-xs mt-0.5">★★★★★ <span class="text-muted">4.8/5</span></div>
            </div>
          </div>
        </div>

        <!-- Right: image -->
        <div class="hidden lg:block anim-up d4">
          <div class="relative">
            <img src="/blog/images/bmw-verte-profil.jpg" alt="BMW sportive, assurance auto malus et résilié avec Allomalus" class="rounded-2xl w-full h-[400px] object-cover" />
            <!-- Floating badges -->
            <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lift border border-border px-4 py-3 flex items-center gap-3">
              <span class="text-2xl">⚡</span>
              <div>
                <p class="text-sm font-bold text-ink">Réponse rapide</p>
                <p class="text-xs text-muted">Jours ouvrés</p>
              </div>
            </div>
            <div class="absolute -top-4 -right-4 bg-white rounded-xl shadow-lift border border-border px-4 py-3 flex items-center gap-3">
              <span class="text-2xl">🛡️</span>
              <div>
                <p class="text-sm font-bold text-ink">Profils difficiles</p>
                <p class="text-xs text-muted">Notre spécialité</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== VEHICULES ====== -->
  <section id="vehicules" class="bg-surface py-24 lg:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Véhicules</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.9] text-ink mb-14">
        Quel véhicule <span class="text-brand">assurer</span> ?
      </h2>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {VEHICULES.map(v => (
          <a href="/devis/" class="group bg-white border border-border rounded-xl p-6 hover:border-brand hover:-translate-y-1 hover:shadow-soft transition-all block">
            <div class="w-10 h-10 rounded-lg bg-brand-pale flex items-center justify-center mb-4 group-hover:bg-brand group-hover:text-white transition-colors">
              {v.id === 'auto' && <svg class="w-5 h-5 text-brand group-hover:text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h17.25M3.375 14.25L6 6.75h12l2.625 7.5"/></svg>}
              {v.id === 'utilitaire' && <svg class="w-5 h-5 text-brand group-hover:text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V6.375c0-.621.504-1.125 1.125-1.125h7.5v12.75m0-12.75h4.875c.621 0 1.125.504 1.125 1.125v3.375M14.25 5.25l3.375 4.5h2.25c.621 0 1.125.504 1.125 1.125V17.625m0 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0"/></svg>}
              {v.id === 'moto' && <svg class="w-5 h-5 text-brand group-hover:text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>}
              {v.id === 'camping-car' && <svg class="w-5 h-5 text-brand group-hover:text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>}
            </div>
            <h3 class="font-display text-lg font-bold text-ink group-hover:text-brand transition-colors">{v.label}</h3>
            <p class="text-xs text-muted mt-1 mb-3">{v.desc}</p>
            <p class="text-sm font-bold text-brand">A partir de {v.from} €/mois</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== PROFILS ====== -->
  <section id="profils" class="bg-surface py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Profils</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.9] text-ink mb-14">
        Votre <span class="text-brand">situation</span>. Notre spécialité.
      </h2>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
        {PROFILS.map(p => (
          <a href="/devis/" class="group bg-white border border-border rounded-xl p-5 hover:border-brand transition-all block">
            <div class="w-8 h-8 rounded-md bg-brand-pale flex items-center justify-center mb-3 group-hover:bg-brand transition-colors">
              <svg class="w-4 h-4 text-brand group-hover:text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg>
            </div>
            <h3 class="font-display text-sm font-bold text-ink group-hover:text-brand transition-colors">{p.label}</h3>
            <p class="text-xs text-muted mt-1">{p.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== ETAPES ====== -->
  <section id="etapes" class="bg-white py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Comment ça marche</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.9] text-ink mb-14">
        <span class="text-brand">Simple</span>. <span class="text-brand">Rapide</span>. <span class="text-brand">Efficace</span>.
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          ['01','📋','Votre demande','Profil, véhicule, historique. Quelques minutes depuis votre téléphone.'],
          ['02','🔍','Notre analyse','Nos experts consultent nos assureurs partenaires pour votre profil.'],
          ['03','📩','Votre offre','Une ou plusieurs propositions adaptées dans votre boite mail.'],
          ['04','🚗','Vous roulez','Vous signez en ligne. Carte verte immédiate.'],
        ].map(([n, ico, title, desc]) => (
          <div class="bg-surface border border-border rounded-xl p-7">
            <span class="font-display text-4xl font-black text-brand/20 block mb-3">{n}</span>
            <span class="text-2xl block mb-3">{ico}</span>
            <h3 class="font-display text-base font-bold text-ink mb-2">{title}</h3>
            <p class="text-sm text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== TEMOIGNAGES ====== -->
  <section class="bg-surface py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Avis clients</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] leading-[0.9] text-ink mb-4">
        Ils étaient dans <span class="text-brand">l'impasse</span>.
      </h2>
      <p class="text-muted mb-14 flex items-center gap-2">
        <span class="text-brand text-sm">★★★★★</span> <strong class="text-ink">4.8/5</strong> sur Google
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          ['"Après 3 refus, Allomalus m\'a trouvé une offre en 48h."','Karim B.','Malussé 1.75'],
          ['"Résiliée après un accident. Ici, pas de jugement. Juste une solution."','Sophie M.','Résiliée'],
          ['"Suspension de permis. A la récupération, impossible de m\'assurer ailleurs."','David T.','Suspendu'],
          ['"Permis depuis 2 ans, déjà un malus. Personne ne voulait de moi."','Fatima L.','Jeune conductrice'],
          ['"Utilitaire résilié. Devis le lendemain, couvert dans la semaine."','Stéphane R.','Artisan BTP'],
        ].map(([txt, name, profil]) => (
          <div class="bg-white border border-border rounded-xl p-6 hover:border-brand/30 transition-colors">
            <div class="text-brand text-xs tracking-[3px] mb-4">★★★★★</div>
            <p class="text-sm text-ink leading-relaxed mb-5">{txt}</p>
            <p class="text-sm font-bold text-ink">{name}</p>
            <p class="text-xs text-muted">{profil}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== COMPARATIF ====== -->
  <section class="bg-white py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">Pourquoi nous</p>
        <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] text-ink">
          <span class="text-brand">Allomalus</span> vs les autres.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-surface border border-border rounded-xl p-8">
          <p class="text-xs font-bold uppercase tracking-[2px] text-muted mb-6">Assureur classique</p>
          {['Réponse en 5 a 10 jours','Profils refusés fréquemment','Suivi standardisé','Déplacement en agence','Vous gérez les sinistres seul'].map(f => (
            <p class="text-sm py-2 flex items-center gap-3 text-muted">
              <span class="text-red-400">✗</span>{f}
            </p>
          ))}
        </div>
        <div class="bg-white border-2 border-brand rounded-xl p-8">
          <p class="text-xs font-bold uppercase tracking-[2px] text-brand mb-6">Allomalus</p>
          {['Réponse rapide','Spécialiste des profils difficiles','Expert dédié a votre dossier','100% en ligne','Accompagnement sinistres'].map(f => (
            <p class="text-sm py-2 flex items-center gap-3 text-ink">
              <span class="text-brand font-bold">✓</span>{f}
            </p>
          ))}
          <a href="/devis/" class="block mt-6 w-full py-3 rounded-lg bg-ink text-white text-center font-bold text-sm hover:bg-ink/80 transition-all">
            Obtenir mon devis &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section id="faq" class="bg-surface py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-[3px] text-brand mb-4">FAQ</p>
      <h2 class="font-display text-[clamp(30px,4.5vw,48px)] font-black tracking-[-2px] text-ink mb-14">
        Vos <span class="text-brand">questions</span>.
      </h2>
      <div class="space-y-2">
        {FAQ_ITEMS.map(item => (
          <details class="group border border-border rounded-xl overflow-hidden bg-white">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-bold text-ink hover:text-brand transition-colors">
              {item.q}
              <svg class="w-4 h-4 text-muted shrink-0 ml-4 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
            </summary>
            <div class="px-5 pb-5 text-sm text-muted leading-relaxed">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FINAL CTA ====== -->
  <section class="bg-ink py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-[clamp(32px,5vw,52px)] font-black tracking-[-3px] leading-[0.9] text-white mb-6">
        Prêt a reprendre la <span class="text-brand">route</span> ?
      </h2>
      <p class="text-white/50 text-lg max-w-md mx-auto mb-10">Peu importe votre situation. On trouve une assurance auto. Toujours.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a href="/devis/" class="inline-flex items-center justify-center gap-2 bg-brand-neon text-ink font-bold text-lg px-10 py-5 rounded-lg hover:bg-brand-light transition-all">
          Devis gratuit &rarr;
        </a>
        <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 bg-white/10 text-white font-bold text-lg px-8 py-5 rounded-lg hover:bg-white/20 transition-all border border-white/10">
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ====== PARTENAIRES + FOOTER ====== -->
  <footer class="bg-white border-t border-border py-10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-wrap justify-center gap-6 text-sm text-muted mb-8">
        <a href="https://prossur.fr" target="_blank" rel="noopener" class="hover:text-brand transition-colors">Prossur - Décennale BTP</a>
        <span class="text-border">|</span>
        <a href="https://formacourtage.fr" target="_blank" rel="noopener" class="hover:text-brand transition-colors">FormaCourtage</a>
      </div>
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-6 border-t border-border">
        <div class="font-display text-lg font-black text-ink"><span class="text-brand">allomalus</span><span class="text-ink">.</span></div>
        <div class="flex gap-5 text-sm text-muted">
          <a href="/mentions-legales/" class="hover:text-ink transition-colors">Mentions légales</a>
          <a href="/devis/" class="hover:text-ink transition-colors">Devis</a>
          <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
        </div>
        <p class="text-xs text-muted">ORIAS {SITE.orias} · SIREN {SITE.siren}</p>
      </div>
    </div>
  </footer>

  <!-- ====== WHATSAPP FLOATING ====== -->
  <a href={waLink} target="_blank" rel="noopener" class="fixed bottom-20 sm:bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lift hover:scale-110 transition-transform" aria-label="Contacter par WhatsApp">
    <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>

  <!-- ====== MOBILE STICKY CTA ====== -->
  <div class="fixed bottom-0 left-0 right-0 z-40 sm:hidden p-3 bg-white/95 backdrop-blur-lg border-t border-border">
    <a href="/devis/" class="block w-full py-3.5 bg-ink text-white text-center font-bold text-sm rounded-lg">
      Mon devis gratuit &rarr;
    </a>
  </div>

  <style>
    @keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-33.33%)} }
    @keyframes up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
    .anim-up { animation: up 0.7s cubic-bezier(0.16,1,0.3,1) forwards; opacity: 0; }
    .d1 { animation-delay: 0.12s; }
    .d2 { animation-delay: 0.24s; }
    .d3 { animation-delay: 0.36s; }
    .d4 { animation-delay: 0.48s; }
  </style>
</Base>
